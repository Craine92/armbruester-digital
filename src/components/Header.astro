---
import Logo from './Logo.astro';
import Button from './Button.astro';
import { navigation } from '@/data/navigation';
import { withBase } from '@/utils/paths';
const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === withBase(href) || (href !== '/' && pathname.startsWith(withBase(href)));
---
<header class="site-header" data-header>
  <div class="site-header__inner container">
    <a class="brand-link" href={withBase('/')} aria-label="Armbrüster Digital – Startseite"><Logo /></a>
    <nav class="desktop-nav" aria-label="Hauptnavigation">
      {navigation.map((item) => <a href={withBase(item.href)} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>)}
    </nav>
    <div class="header-actions">
      <Button href="/kontakt/" class="header-cta">Projekt anfragen</Button>
      <button class="menu-toggle" type="button" aria-label="Menü öffnen" aria-expanded="false" aria-controls="mobile-menu" data-menu-toggle>
        <span></span><span></span>
      </button>
    </div>
  </div>
  <div class="mobile-menu" id="mobile-menu" data-mobile-menu role="dialog" aria-modal="true" aria-label="Mobiles Hauptmenü" hidden>
    <nav aria-label="Mobile Navigation">
      {navigation.map((item, index) => <a href={withBase(item.href)} data-menu-link aria-current={isActive(item.href) ? 'page' : undefined}><span>0{index + 1}</span>{item.label}</a>)}
    </nav>
    <p>Webdesign · SEO · Digitale Präsenz<br />Persönlich aus Lübeck.</p>
  </div>
  <noscript>
    <style>.menu-toggle{display:none!important}.noscript-nav{display:flex!important}</style>
    <nav class="noscript-nav container" aria-label="Navigation ohne JavaScript">
      {navigation.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
    </nav>
  </noscript>
</header>

<script>
  const initHeader = () => {
    const header = document.querySelector<HTMLElement>('[data-header]');
    const toggle = header?.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    const menu = header?.querySelector<HTMLElement>('[data-mobile-menu]');
    if (!header || !toggle || !menu) return;
    const state = window as Window & { armbruesterHeaderController?: AbortController };
    state.armbruesterHeaderController?.abort();
    const controller = new AbortController();
    state.armbruesterHeaderController = controller;
    const { signal } = controller;
    let previousFocus: HTMLElement | null = null;
    let scrollPosition = 0;
    const links = () => [...menu.querySelectorAll<HTMLElement>('a, button')];
    const close = (restore = true) => {
      if (toggle.getAttribute('aria-expanded') !== 'true') return;
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Menü öffnen');
      header.classList.remove('menu-open');
      document.documentElement.classList.remove('nav-open');
      document.body.classList.remove('nav-open');
      document.body.style.removeProperty('top');
      document.querySelectorAll<HTMLElement>('main, .site-footer').forEach((element) => { element.inert = false; });
      menu.hidden = true;
      window.scrollTo(0, scrollPosition);
      if (restore) previousFocus?.focus();
    };
    const open = () => {
      previousFocus = document.activeElement as HTMLElement;
      scrollPosition = window.scrollY;
      document.body.style.top = `-${scrollPosition}px`;
      document.documentElement.classList.add('nav-open');
      document.body.classList.add('nav-open');
      document.querySelectorAll<HTMLElement>('main, .site-footer').forEach((element) => { element.inert = true; });
      menu.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Menü schließen');
      header.classList.add('menu-open');
      links()[0]?.focus();
    };
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Menü öffnen');
    header.classList.remove('menu-open');
    menu.hidden = true;
    document.documentElement.classList.remove('nav-open');
    document.body.classList.remove('nav-open');
    document.body.style.removeProperty('top');
    document.querySelectorAll<HTMLElement>('main, .site-footer').forEach((element) => { element.inert = false; });
    toggle.addEventListener('click', () => toggle.getAttribute('aria-expanded') === 'true' ? close(false) : open(), { signal });
    menu.addEventListener('click', (event) => { if ((event.target as Element).closest('a')) close(false); }, { signal });
    document.addEventListener('keydown', (event) => {
      if (toggle.getAttribute('aria-expanded') !== 'true') return;
      if (event.key === 'Escape') { event.preventDefault(); close(); return; }
      if (event.key === 'Tab') {
        const focusable = [toggle, ...links()]; const first = focusable[0]; const last = focusable.at(-1);
        if (event.shiftKey && document.activeElement === first) { event.preventDefault(); last?.focus(); }
        else if (!event.shiftKey && document.activeElement === last) { event.preventDefault(); first.focus(); }
      }
    }, { signal });
    const desktopQuery = window.matchMedia('(min-width: 961px)');
    desktopQuery.addEventListener('change', (event) => { if (event.matches) close(false); }, { signal });
    const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 24);
    onScroll(); window.addEventListener('scroll', onScroll, { passive: true, signal });
  };
  document.addEventListener('astro:page-load', initHeader); initHeader();
</script>
