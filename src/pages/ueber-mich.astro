---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import CallToAction from '@/components/CallToAction.astro';
import { siteConfig } from '@/config/site';
import { withBase } from '@/utils/paths';
---
<BaseLayout title="Über mich | Philipp Armbrüster" description="Philipp Armbrüster entwickelt persönliche, moderne Websites für kleine Unternehmen – mit technischem Hintergrund, klarer Kommunikation und Sitz in Lübeck." path="/ueber-mich/" breadcrumbs={[{name:'Startseite',path:'/'},{name:'Über mich',path:'/ueber-mich/'}]}>
  <section class="page-hero"><div class="container page-hero__inner"><div><p class="eyebrow">Über mich</p><h1>Digitale Lösungen brauchen Verständnis – für Technik und für <em>Menschen.</em></h1></div><p class="page-hero__intro"><strong>Philipp Armbrüster</strong>Persönlicher Ansprechpartner, technischer Umsetzer und der Mensch hinter Armbrüster Digital.</p></div></section>
  <section class="content-section"><div class="container about-teaser"><div class="portrait reveal"><img src={withBase(siteConfig.images.portrait)} alt="Neutraler Platzhalter für ein zukünftiges Porträt von Philipp Armbrüster" width="800" height="1000" /></div><div class="about-copy prose reveal"><p class="eyebrow">Persönlich aus Lübeck</p><h2>Gute Zusammenarbeit beginnt mit einem direkten Gespräch.</h2><p>Ich bin Philipp Armbrüster und entwickle mit Armbrüster Digital moderne Online-Auftritte für kleine Unternehmen und Selbstständige. Mein technischer Hintergrund in der Webentwicklung verbindet sich dabei mit einem klaren Blick für Gestaltung, Benutzerfreundlichkeit und nachvollziehbare Lösungen.</p><p>Mir ist wichtig, dass eine Website nicht nur gut aussieht. Sie soll zum Unternehmen passen, Vertrauen schaffen, schnell funktionieren und von potenziellen Kunden gefunden werden können.</p><p>Deshalb begleite ich jedes Projekt persönlich: vom ersten Gespräch und der Struktur über Design und Entwicklung bis zur Veröffentlichung. Sie sprechen direkt mit der Person, die Entscheidungen vorbereitet und die Website umsetzt.</p><p>Die Zusammenarbeit ist aus Lübeck ebenso regional wie deutschlandweit möglich. Abstimmungen bleiben verbindlich, verständlich und auf das Wesentliche konzentriert.</p><Button href="/kontakt/">Unverbindlich kennenlernen</Button></div></div></section>
  <section class="content-section surface-section"><div class="container"><div class="contrast-list"><div class="contrast-item"><span>01</span><strong>Klar zuhören</strong><span>Standardantworten</span></div><div class="contrast-item"><span>02</span><strong>Verständlich beraten</strong><span>Fachsprache</span></div><div class="contrast-item"><span>03</span><strong>Verlässlich umsetzen</strong><span>anonyme Übergaben</span></div></div></div></section><CallToAction compact />
</BaseLayout>
